<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <ImageButton
            android:id="@+id/btnBackFromRecords"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Vissza" />

        <TextView
            android:id="@+id/tvRecordsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/medical_records_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMedicalRecords"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextView
        android:id="@+id/tvEmptyRecords"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nincsenek elérhető kórlapok."
        android:gravity="center"
        android:layout_marginTop="50dp"
        android:visibility="gone" />

</LinearLayout>